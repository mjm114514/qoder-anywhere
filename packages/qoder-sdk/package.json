{
  "name": "qoder-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for qodercli — spawn and interact with Qoder AI agent via NDJSON stdio protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
